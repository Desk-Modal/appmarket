{
  "model": "claude-opus-4-7",
  "outputStyle": "concise",
  "statusLine": {
    "type": "command",
    "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/statusline.sh\""
  },
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(cargo check:*)",
      "Bash(cargo build:*)",
      "Bash(cargo test:*)",
      "Bash(cargo fmt:*)",
      "Bash(cargo clippy:*)",
      "Bash(cargo run:*)",
      "Bash(cargo tree:*)",
      "Bash(cargo bench:*)",
      "Bash(pnpm install:*)",
      "Bash(pnpm nx:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm build:*)",
      "Bash(npx vitest:*)",
      "Bash(npx tsc:*)",
      "Bash(npm test:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git ls-files:*)",
      "Bash(git rev-parse:*)",
      "Bash(git remote:*)",
      "Bash(git stash list:*)",
      "Bash(git stash push:*)",
      "Bash(git stash pop:*)",
      "Bash(git mv:*)",
      "Bash(scripts/local-ci.sh:*)",
      "Bash(scripts/build-dist.sh:*)",
      "Bash(scripts/launch.sh:*)",
      "Bash(scripts/prod-check.sh:*)",
      "Bash(scripts/pod-apply.sh:*)",
      "Bash(./scripts/*:*)",
      "Bash(./tools/*:*)",
      "Bash(.claude/scripts/*:*)",
      "Bash(mise:*)",
      "Bash(dmpkg:*)",
      "Bash(python scripts/cdp-test-runner.py:*)",
      "Bash(python scripts/*.py:*)",
      "Bash(python3 scripts/*.py:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr create:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh run watch:*)",
      "Bash(gh workflow list:*)",
      "Bash(gh workflow view:*)",
      "Bash(gh auth status:*)",
      "Bash(gh api repos/*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git reset --hard:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh pr close:*)",
      "Bash(gh release:*)",
      "Bash(pnpm publish:*)",
      "Bash(npm publish:*)",
      "Bash(cargo publish:*)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf *)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git reflog expire:*)",
      "Bash(git filter-branch:*)",
      "Bash(curl *| sh:*)",
      "Bash(curl *| bash:*)",
      "Bash(wget *| sh:*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(**/publisher.key)",
      "Read(**/*.pem)",
      "Write(./.env)",
      "Write(./.env.*)",
      "Write(./secrets/**)"
    ]
  },
  "env": {
    "DESKMODAL_WORKSPACE": "${CLAUDE_PROJECT_DIR}",
    "DESKMODAL_TOOLS": "${CLAUDE_PROJECT_DIR}/tools",
    "PYTHONDONTWRITEBYTECODE": "1",
    "RUSTFLAGS": "-C debuginfo=line-tables-only"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/context-load.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/post-commit-handoff.sh\""
          }
        ]
      }
    ]
  }
}
