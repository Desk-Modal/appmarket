{
  "env": {
    "DESKMODAL_WORKSPACE": "${CLAUDE_PROJECT_DIR}",
    "DESKMODAL_TOOLS": "${CLAUDE_PROJECT_DIR}/tools",
    "PYTHONDONTWRITEBYTECODE": "1",
    "RUSTFLAGS": "-C debuginfo=line-tables-only"
  },
  "permissions": {
    "allow": [
      "Bash(cargo check:*)",
      "Bash(cargo build:*)",
      "Bash(cargo test:*)",
      "Bash(cargo fmt:*)",
      "Bash(cargo clippy:*)",
      "Bash(cargo run:*)",
      "Bash(cargo tree:*)",
      "Bash(cargo bench:*)",
      "Bash(pnpm install:*)",
      "Bash(pnpm nx:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm build:*)",
      "Bash(npx vitest:*)",
      "Bash(npx tsc:*)",
      "Bash(npm test:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git ls-files:*)",
      "Bash(git rev-parse:*)",
      "Bash(git remote:*)",
      "Bash(git stash list:*)",
      "Bash(git stash push:*)",
      "Bash(git stash pop:*)",
      "Bash(git mv:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git push)",
      "Bash(git pull:*)",
      "Bash(git pull --rebase:*)",
      "Bash(git checkout:*)",
      "Bash(git rebase:*)",
      "Bash(git fetch:*)",
      "Bash(git tag:*)",
      "Bash(git config:*)",
      "Bash(git rev-list:*)",
      "Bash(git symbolic-ref:*)",
      "Bash(git apply:*)",
      "Bash(git cherry-pick:*)",
      "Bash(scripts/local-ci.sh:*)",
      "Bash(scripts/build-dist.sh:*)",
      "Bash(scripts/launch.sh:*)",
      "Bash(scripts/prod-check.sh:*)",
      "Bash(scripts/pod-apply.sh:*)",
      "Bash(scripts/wave-sandbox.sh:*)",
      "Bash(scripts/wiki-lint.sh:*)",
      "Bash(scripts/wiki-coverage.sh:*)",
      "Bash(scripts/wiki-mirror.sh:*)",
      "Bash(scripts/wiki-gen-personas.sh:*)",
      "Bash(scripts/wiki-gen-mcps.sh:*)",
      "Bash(scripts/wiki-gen-compat-ladder.sh:*)",
      "Bash(scripts/wiki-gen-hooks.sh:*)",
      "Bash(scripts/wiki-gen-plugins.sh:*)",
      "Bash(scripts/wiki-gen-tokens.sh:*)",
      "Bash(scripts/wiki-gen-apis.sh:*)",
      "Bash(scripts/wiki-mcp-server.py:*)",
      "Bash(scripts/*:*)",
      "Bash(./scripts/*:*)",
      "Bash(./tools/*:*)",
      "Bash(.claude/scripts/*:*)",
      "Bash(.claude/hooks/*.sh:*)",
      "Bash(mise:*)",
      "Bash(dmpkg:*)",
      "Bash(python scripts/cdp-test-runner.py:*)",
      "Bash(python scripts/*.py:*)",
      "Bash(python3 scripts/*.py:*)",
      "Bash(python3 -m wiki_*:*)",
      "Bash(python3 -c:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(diff:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(jq:*)",
      "Bash(chmod:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Bash(cd:*)",
      "Bash(pwd:*)",
      "Bash(mktemp:*)",
      "Bash(test:*)",
      "Bash(true:*)",
      "Bash(false:*)",
      "Bash(env:*)",
      "Bash(date:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(tr:*)",
      "Bash(cut:*)",
      "Bash(xargs:*)",
      "Bash(tee:*)",
      "Bash(yes:*)",
      "Bash(timeout:*)",
      "Bash(wait:*)",
      "Bash(sleep:*)",
      "Bash(ps:*)",
      "Bash(kill:*)",
      "Bash(pkill:*)",
      "Bash(disown:*)",
      "Bash(for:*)",
      "Bash(while:*)",
      "Bash(if:*)",
      "Bash(bash:*)",
      "Bash(sh:*)",
      "Bash(npm install:*)",
      "Bash(npm run:*)",
      "Bash(npm audit:*)",
      "Bash(pnpm:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr create:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh run watch:*)",
      "Bash(gh workflow list:*)",
      "Bash(gh workflow view:*)",
      "Bash(gh auth status:*)",
      "Bash(gh api repos/*)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf *)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git reflog expire:*)",
      "Bash(git filter-branch:*)",
      "Bash(curl *| sh:*)",
      "Bash(curl *| bash:*)",
      "Bash(wget *| sh:*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(**/publisher.key)",
      "Read(**/*.pem)",
      "Write(./.env)",
      "Write(./.env.*)",
      "Write(./secrets/**)"
    ],
    "ask": [
      "Bash(git reset --hard:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh pr close:*)",
      "Bash(gh release:*)",
      "Bash(pnpm publish:*)",
      "Bash(npm publish:*)",
      "Bash(cargo publish:*)"
    ],
    "defaultMode": "acceptEdits"
  },
  "model": "claude-opus-4-7",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/bootstrap-plugins.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/context-load.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/post-commit-handoff.sh\""
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/statusline.sh\""
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "chrome-devtools-mcp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true
  },
  "outputStyle": "concise"
}
