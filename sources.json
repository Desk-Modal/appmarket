{
  "comment": "Declarative source list for the DeskModal App Market. The aggregator reads GitHub Releases from these repos and builds the catalog. CODEOWNERS-gated — third parties submit a publisher-signup issue, Desk-Modal adds their entry.",
  "publisher_keys": {
    "deskmodal-ci": {
      "algorithm": "ed25519",
      "source": "GitHub App (deskmodal-ci) signing key",
      "owner": "Desk-Modal"
    }
  },
  "categories": [
    { "id": "trading",    "name": "Trading",    "description": "Order entry, blotter, positions, portfolio" },
    { "id": "charting",   "name": "Charting",   "description": "Price charts, indicators, drawing tools" },
    { "id": "data",       "name": "Data",       "description": "Market data feeds and streaming" },
    { "id": "analytics",  "name": "Analytics",  "description": "Cross-instrument analysis and metrics" },
    { "id": "simulation", "name": "Simulation", "description": "Paper trading, backtesting, replay" },
    { "id": "scripting",  "name": "Scripting",  "description": "Indicator and strategy scripting" },
    { "id": "branding",   "name": "Branding",   "description": "Brand themes and white-label packs" },
    { "id": "platform",   "name": "Platform",   "description": "DeskModal agent and core components" }
  ],
  "bundled_packs": [
    {
      "id": "deskmodal-default",
      "type": "theme",
      "name": "DeskModal Default",
      "tagline": "The original DeskModal brand — dark navy + brand red-orange",
      "description": "The original DeskModal brand pack: dark navy + brand red-orange accent. Apple-school glass, OKLCH-aligned, 4px grid. Ships pre-installed with DeskModal.",
      "categories": ["branding"],
      "tags": ["theme", "brand", "default", "dark"],
      "featured": true,
      "publisher": { "id": "deskmodal", "name": "DeskModal Technologies", "verified": true },
      "version": "1.0.0",
      "license": "Proprietary"
    }
  ],
  "sources": [
    {
      "owner": "Desk-Modal",
      "repo": "deskmodal",
      "mode": "single_release",
      "content_type": "platform",
      "id": "deskmodal",
      "display_name": "DeskModal",
      "tagline": "FDC3 2.2 Desktop Agent for multi-asset trading",
      "categories": ["platform"],
      "tags": ["agent", "fdc3", "desktop"],
      "featured": true,
      "asset_name_template": "DeskModal-{version}-{platform}.{ext}"
    },
    {
      "owner": "Desk-Modal",
      "repo": "tradesurface",
      "mode": "multi_plugin_release",
      "content_type": "app",
      "plugins": [
        { "slug": "feeds",        "id": "deskmodal.feeds",        "display_name": "Price Feed Hub",      "tagline": "Real-time multi-exchange price feeds",          "categories": ["data"],        "featured": true  },
        { "slug": "chart",        "id": "deskmodal.chart",        "display_name": "Chart",               "tagline": "Advanced charting with 50+ indicators",         "categories": ["charting"],    "featured": true  },
        { "slug": "watchlist",    "id": "deskmodal.watchlist",    "display_name": "Watchlist",           "tagline": "Multi-exchange watchlist with streaming quotes", "categories": ["trading"],     "featured": true  },
        { "slug": "depth",        "id": "deskmodal.depth",        "display_name": "Depth",               "tagline": "Cross-exchange order book depth",                "categories": ["trading"],     "featured": false },
        { "slug": "analytics",    "id": "deskmodal.analytics",    "display_name": "Analytics",           "tagline": "Market analytics and cross-exchange metrics",    "categories": ["analytics"],   "featured": false },
        { "slug": "screener",     "id": "deskmodal.screener",     "display_name": "Screener",            "tagline": "Real-time market screener with custom filters",  "categories": ["trading"],     "featured": false },
        { "slug": "alerts",       "id": "deskmodal.alerts",       "display_name": "Alerts",              "tagline": "Price alerts and condition monitoring",          "categories": ["trading"],     "featured": false },
        { "slug": "order-ticket", "id": "deskmodal.order-ticket", "display_name": "Order Ticket",        "tagline": "Order entry widget",                             "categories": ["trading"],     "featured": true  },
        { "slug": "blotter",      "id": "deskmodal.blotter",      "display_name": "Order Blotter",       "tagline": "Working and filled orders log",                  "categories": ["trading"],     "featured": false },
        { "slug": "positions",    "id": "deskmodal.positions",    "display_name": "Positions",           "tagline": "Cross-exchange position viewer",                 "categories": ["trading"],     "featured": false },
        { "slug": "news",         "id": "deskmodal.news",         "display_name": "News Wire",           "tagline": "Real-time news with 4-state severity ribbon, multi-source aggregation, drag-to-chart annotations", "categories": ["data"],        "featured": true  },
        { "slug": "earnings",     "id": "deskmodal.earnings",     "display_name": "Earnings Calendar",   "tagline": "Week-grid earnings + crypto unlocks with implied-move, consensus blend, post-event reaction tracker", "categories": ["data", "trading"], "featured": true }
      ],
      "services": [
        { "id": "deskmodal.price-feed",     "display_name": "Price Feed Service",     "tagline": "Multi-exchange WebSocket streaming",     "categories": ["data"],       "featured": true  },
        { "id": "deskmodal.paper-trading",  "display_name": "Paper Trading Service",  "tagline": "Risk-free order simulation with realistic fills", "categories": ["trading", "simulation"], "featured": true  },
        { "id": "deskmodal.news-feed",      "display_name": "News Feed Service",      "tagline": "Multi-source news aggregation: Cryptopanic, NewsAPI, RSS, Coinbase, Binance", "categories": ["data"], "featured": false },
        { "id": "deskmodal.earnings-feed",  "display_name": "Earnings Feed Service",  "tagline": "Multi-source earnings + crypto-events: FMP, Polygon, CryptoRank, EarningsWhispers", "categories": ["data"], "featured": false }
      ],
      "asset_name_template": "tradesurface-{slug}-{version}-{platform}.dmpkg"
    },
    {
      "owner": "Desk-Modal",
