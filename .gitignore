# Aggregator scratch files
/tmp/
*.pyc
__pycache__/

# Build artefacts — appmarket is a registry, not a source repo. Binaries
# live on GitHub Releases (mirrored by aggregate.py); they must NEVER land
# in the git tree. Historical commits filtered 2026-05-05.
target/
node_modules/
dist/
releases/

# Signing keys must NEVER be committed — they live in GitHub Actions secrets
*.pem
*.key
DESKMODAL_SIGNING_KEY

# Catalog signing key — Ed25519 secret never committed.
# Public hex lives in CATALOG_PUBKEY.md (committed) for clients to set
# DESKMODAL_CATALOG_PUBKEY_HEX env var; the private key stays local /
# in GitHub Actions secrets.
.signing-key.hex
.signing-key.bin
